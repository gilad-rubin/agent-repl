{
  "name": "agent-repl",
  "displayName": "Agent REPL",
  "description": "Multiplayer Jupyter notebooks — AI agents and humans collaborate in real time",
  "version": "0.3.0",
  "publisher": "GiladRubin",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onNotebook:jupyter-notebook",
    "workspaceContains:**/*.ipynb"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent-repl.start",
        "title": "Agent REPL: Start Bridge"
      },
      {
        "command": "agent-repl.stop",
        "title": "Agent REPL: Stop Bridge"
      },
      {
        "command": "agent-repl.askAgent",
        "title": "Agent REPL: Ask Agent",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agent-repl.reload",
        "title": "Agent REPL: Reload"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "agent-repl.askAgent",
          "group": "navigation",
          "when": "notebookType == jupyter-notebook"
        }
      ]
    },
    "configuration": {
      "title": "Agent REPL",
      "properties": {
        "agent-repl.port": {
          "type": "number",
          "default": 0,
          "description": "Fixed port (0 = auto)"
        },
        "agent-repl.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start bridge when the workspace loads"
        },
        "agent-repl.sessionAutoAttach": {
          "type": "boolean",
          "default": true,
          "description": "Automatically attach the VS Code window to the shared workspace session when the bridge starts"
        },
        "agent-repl.cliCommand": {
          "type": "string",
          "default": "",
          "description": "Optional explicit path or command name for launching the agent-repl CLI from the extension host"
        },
        "agent-repl.pyrightCommand": {
          "type": "string",
          "default": "",
          "description": "Optional executable path or command name for launching pyright-langserver from the extension host. Leave empty to use the bundled Pyright server."
        },
        "agent-repl.browserCanvasUrl": {
          "type": "string",
          "default": "http://127.0.0.1:4173/preview.html",
          "description": "Base URL for opening the standalone browser canvas. Used by 'agent-repl open --target browser' and 'agent-repl new --open --target browser'."
        },
        "agent-repl.maxQueueSize": {
          "type": "number",
          "default": 20,
          "description": "Max queued executions"
        },
        "agent-repl.executionTimeout": {
          "type": "number",
          "default": 300,
          "description": "Execution timeout (seconds)"
        },
        "agent-repl.executionMode": {
          "type": "string",
          "enum": [
            "no-yank",
            "native"
          ],
          "enumDescriptions": [
            "Prefer the background Jupyter execution path and only fall back to the notebook command when needed.",
            "Always use VS Code's native notebook execution command, even if it steals focus."
          ],
          "default": "no-yank",
          "description": "How agent-triggered notebook execution should behave."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-repl",
          "title": "Agent REPL",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "agent-repl": [
        {
          "type": "webview",
          "id": "agent-repl.activity",
          "name": "Activity"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "agent-repl.canvasEditor",
        "displayName": "Agent REPL Canvas",
        "selector": [
          {
            "filenamePattern": "*.ipynb"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "build:webview": "node ./scripts/build-webview.mjs",
    "preview:webview": "node ./scripts/preview-webview.mjs",
    "compile": "npm run build:webview && tsc -p ./",
    "test": "npm run compile && node --test tests/*.test.js",
    "test:preview": "node --test tests/preview-webview.smoke.js",
    "test:artifact": "npm run package && node scripts/check-session-auto-attach-package.js",
    "test:installed-session-auto-attach": "npm run compile && node tests/session-installed-auto-attach.smoke.js",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package --allow-missing-repository",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@carbon/icons-react": "^11.77.0",
    "@carbon/react": "^1.104.0",
    "@carbon/styles": "^1.103.0",
    "@carbon/themes": "^11.70.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.5.2",
    "agentation": "^3.0.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "esbuild": "^0.27.4",
    "marked": "^17.0.5",
    "motion": "^12.38.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@codemirror/lint": "^6.9.5",
    "interface-kit": "^0.1.3",
    "pyright": "^1.1.408"
  }
}
