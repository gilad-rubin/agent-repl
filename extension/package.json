{
  "name": "agent-repl",
  "displayName": "Agent REPL",
  "description": "Multiplayer Jupyter notebooks — AI agents and humans collaborate in real time",
  "version": "0.2.0",
  "publisher": "GiladRubin",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": ["Notebooks", "Other"],
  "activationEvents": [
    "onStartupFinished",
    "onNotebook:jupyter-notebook",
    "workspaceContains:**/*.ipynb"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "agent-repl.start", "title": "Agent REPL: Start Bridge" },
      { "command": "agent-repl.stop", "title": "Agent REPL: Stop Bridge" },
      { "command": "agent-repl.askAgent", "title": "Agent REPL: Ask Agent", "icon": "$(comment-discussion)" }
    ],
    "menus": {
      "notebook/toolbar": [
        { "command": "agent-repl.askAgent", "group": "navigation", "when": "notebookType == jupyter-notebook" }
      ]
    },
    "configuration": {
      "title": "Agent REPL",
      "properties": {
        "agent-repl.port": { "type": "number", "default": 0, "description": "Fixed port (0 = auto)" },
        "agent-repl.autoStart": { "type": "boolean", "default": true, "description": "Start bridge when the workspace loads" },
        "agent-repl.maxQueueSize": { "type": "number", "default": 20, "description": "Max queued executions" },
        "agent-repl.executionTimeout": { "type": "number", "default": 300, "description": "Execution timeout (seconds)" },
        "agent-repl.executionMode": {
          "type": "string",
          "enum": ["no-yank", "native"],
          "enumDescriptions": [
            "Prefer the background Jupyter execution path and only fall back to the notebook command when needed.",
            "Always use VS Code's native notebook execution command, even if it steals focus."
          ],
          "default": "no-yank",
          "description": "How agent-triggered notebook execution should behave."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "agent-repl", "title": "Agent REPL", "icon": "$(terminal)" }
      ]
    },
    "views": {
      "agent-repl": [
        { "type": "webview", "id": "agent-repl.activity", "name": "Activity" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test tests/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.86.0",
    "typescript": "^5.3.0"
  }
}
